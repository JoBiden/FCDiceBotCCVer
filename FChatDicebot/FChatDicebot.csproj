  <ItemGroup>
    <!-- Every .cs under the project directory is compiled via this glob, so a new
         file added on disk is built automatically (previously each file needed an
         explicit <Compile Include> entry here, and a forgotten entry meant the file
         silently did not build). Caveat: adding a file through the classic VS
         Solution Explorer may expand this wildcard back into explicit entries -
         prefer creating files on disk directly.

         Model\MonsterGenerator\** stays excluded: it is the incomplete
         MonsterGenerator subsystem, whose files live in the
         MonsterGenerator2_Net47.Models.Data namespace and reference model types
         (Alignment, Race, RandomGenerationTable, AbilityModel, FeatModel, etc.)
         that were never ported into this repo, so they cannot compile. Nothing
         outside that folder references them (the !monsterize command uses the
         Chateau interaction system, not this code). The files are retained on disk
         so the feature can be completed later by porting the missing
         MonsterGenerator2_Net47.Models definitions and removing them from the
         Exclude list. -->
    <Compile Include="**\*.cs" Exclude="bin\**;obj\**;packages\**;Model\MonsterGenerator\**" />
  </ItemGroup>
