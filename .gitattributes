# Auto-detect text files and normalize line endings to LF in the index.
# On Windows checkout, core.autocrlf=true / core.eol=native restores CRLF.
* text=auto

# Explicit binary types (don't try to diff or normalize)
*.zip   binary
*.dll   binary
*.exe   binary
*.pdb   binary
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.snk   binary
*.nupkg binary
